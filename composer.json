{
    "name": "anas/easy-dev",
    "description": "🚀 A powerful Laravel package that supercharges development with beautiful UI, interactive CRUD generation, Repository & Service patterns, and intelligent relationship detection.",
    "type": "laravel-package",
    "version": "2.0.0",
    "license": "MIT",
    "keywords": [
        "laravel",
        "artisan", 
        "crud",
        "generator",
        "repository",
        "service",
        "ui",
        "interactive",
        "development",
        "scaffolding",
        "relationships",
        "commands",
        "laravel-package",
        "productivity",
        "automation"
    ],
    "homepage": "https://github.com/anasnashat/laravel-easy-dev",
    "readme": "README.md",
    "authors": [
        {
            "name": "Anas Nashaat",
            "email": "anas.nashat.ahmed@gmail.com",
            "homepage": "https://github.com/anasnashat",
            "role": "Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/anasnashat/laravel-easy-dev/issues",
        "source": "https://github.com/anasnashat/laravel-easy-dev",
        "docs": "https://github.com/anasnashat/laravel-easy-dev#readme"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/anasnashat"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/console": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/database": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/filesystem": "^9.0|^10.0|^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "AnasNashat\\EasyDev\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AnasNashat\\EasyDev\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AnasNashat\\EasyDev\\Providers\\EasyDevServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "2.0-dev"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
